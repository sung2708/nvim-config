{
  "coc.preferences.formatOnSave": true,
  "coc.preferences.formatOnSaveFiletypes": [
    "javascript",
    "typescript",
    "typescriptreact",
    "javascriptreact",
    "json",
    "css",
    "scss",
    "markdown",
    "vim"
  ],

  "eslint.enable": true,
  "eslint.autoFixOnSave": true,
  "eslint.filetypes": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact",
    "vue"
  ],

  "prettier.enable": true,
  "prettier.statusItemText": true,

  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": true,
    "source.fixAll.ruff": true,
    "source.organizeImports.ruff": true
  },

  "typescript.format.enable": false,
  "javascript.format.enable": false,

  "ruff.enable": true,
  "ruff.nativeServer": true,
  "ruff.autoFixOnSave": true,
  "ruff.formatOnSave": true,

  "python.formatting.provider": "none",

  "suggest.floatConfig": { "border": true, "rounded": true },
  "diagnostic.floatConfig": { "border": true, "rounded": true },
  "hover.floatConfig": { "border": true, "rounded": true },
  "signature.floatConfig": {
    "border": true,
    "rounded": true
  },
  "snippets.ultisnips.pythonPrompt": false,
  "suggest.completionItemKindLabels": {
    "text": "≤░Κ┐",
    "method": "≤░Ηπ",
    "function": "≤░ΛΧ",
    "constructor": "ΎΡμ",
    "field": "≤░ελ",
    "variable": "≤░Ατ",
    "class": "≤░ι▒",
    "interface": "ΎΔρ",
    "module": "ΎΤΘ",
    "property": "≤░ελ",
    "unit": "≤░Σφ",
    "value": "≤░Οθ",
    "enum": "ΎΖζ",
    "keyword": "≤░ΝΜ",
    "snippet": "ΎΣΠ",
    "color": "≤░Πα",
    "file": "≤░Ιβ",
    "reference": "≤░ΙΘ",
    "folder": "≤░ΚΜ",
    "enumMember": "ΎΖζ",
    "constant": "≤░Π┐",
    "struct": "≤░βΖ",
    "event": "ΎΔπ",
    "operator": "≤░ΗΧ",
    "typeParameter": "≤░Ζ▓",
    "default": "≤░Ζσ"
  }
}
